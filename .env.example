HOST=http://localhost:8000
SECRET_KEY=some-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://username@localhost:5432/techpourtoutes

# Email (Brevo/Anymail — only needed in production; local uses Mailpit on port 1025)
# Install: brew install mailpit — run with: mailpit — UI at http://localhost:8025
DEFAULT_FROM_EMAIL=Tech Pour Toutes <bonjour@techpourtoutes.io>
BREVO_API_KEY=some-key

# Brevo contacts sync
# BREVO_SYNC_ENABLED=False désactive globalement la synchro (signaux + tâches Celery).
# À mettre à True uniquement en prod (ou pour tester la synchro en local).
BREVO_SYNC_ENABLED=False
BREVO_PRO_LIST_ID=2

# Coalition — destinataires notifiés à chaque nouvelle demande (listes séparées par des virgules)
COALITION_INTERNSHIPS_RECIPIENTS=example@mail.com
COALITION_WORK_AMBASSADOR_RECIPIENTS=example@mail.com,example@mail.com
COALITION_TRAINING_AMBASSADOR_RECIPIENTS=example@mail.com
COALITION_SPONSOR_RECIPIENTS=example@mail.com,example@mail.com

# Jobirl API
# En local ou en staging : JOBIRL_URL=https://preprod.jobirl.com
# En prod : JOBIRL_URL=https://www.jobirl.com
# Pour simuler une erreur, modifier _mock_status dans api/views.py et redémarrer
JOBIRL_URL=https://preprod.jobirl.com
JOBIRL_API_KEY=some-token

#Latitudes interco
N8N_WORKSHOP_WEBHOOK_URL=some_url
N8N_WORKSHOP_WEBHOOK_BASIC_AUTH_USER=some-user
N8N_WORKSHOP_WEBHOOK_BASIC_AUTH_PASSWORD=some-password

# Celery / Redis
# En local sans Redis, mettre CELERY_TASK_ALWAYS_EAGER=True pour exécuter les tâches en synchrone
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# Sentry (optionnel — laisser vide pour désactiver)
SENTRY_DSN=

# Huwise - pour requêtes sur l'API data.education.gouv.fr
HUWISE_API_KEY=some_key
